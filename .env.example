# Copie este arquivo para .env e preencha com seus valores.
# .env nunca é commitado (veja .gitignore) e nunca é lido por ferramentas
# externas — só por node server.js / clipper/*.js (lib/loadEnv.js).

# Picking de momentos via IA no auto-clipper (opcional — sem isso, usa o
# hook-detector offline). Exemplo abaixo aponta pra camada de compatibilidade
# OpenAI da Anthropic — veja o README para outros provedores (DeepSeek, Ollama...).
LLM_BASE_URL=https://api.anthropic.com/v1
LLM_API_KEY=sk-ant-...
LLM_MODEL=claude-opus-4-8

# Porta do servidor (opcional, padrão 4870)
# PORT=4870
